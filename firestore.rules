rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string && data.email.size() <= 200;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'restaurantId', 'items', 'total', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.status in ['pending', 'preparing', 'out_for_delivery', 'delivered', 'cancelled'] &&
             data.total is number && data.total >= 0 &&
             data.items is list && data.items.size() > 0 &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'preferences', 'favorites', 'address']);
    }

    // Restaurants
    match /restaurants/{restaurantId} {
      allow list, get: if true; // Publicly viewable
      // Create/Update would normally be Admin only, keeping locked for now or allow user-confirmed admin
      allow write: if false;

      // Menu subcollection
      match /menu/{itemId} {
        allow list, get: if true;
        allow write: if false;
      }
    }

    // Orders
    match /orders/{orderId} {
      allow list: if isSignedIn() && existing().userId == request.auth.uid;
      allow get: if isSignedIn() && (existing().userId == request.auth.uid);
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'deliveryAddress']) &&
                    isValidOrder(incoming());
    }
  }
}
